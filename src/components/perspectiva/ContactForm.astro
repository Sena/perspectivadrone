---
import { PortableText } from "emdash/ui";

const { entry, instagram = "" } = Astro.props;
const data = entry?.data || {};
---
<section id="contato" class="py-24 px-6 max-w-7xl mx-auto">
  <div class="grid md:grid-cols-2 gap-16 items-start">
    <!-- Left side -->
    <div>
      <p class="coord-text mb-3 text-primary-80">/ 04 — Contato</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight font-display" {...entry?.edit?.title}>
        {data.title}
      </h2>
      <div class="mb-10 leading-relaxed text-white/60 font-sans font-light" {...entry?.edit?.content}>
        <PortableText value={data.content} />
      </div>

      <div class="space-y-5">
        <a href={`https://www.instagram.com/${instagram}/`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
          <div class="w-10 h-10 border flex items-center justify-center transition-all duration-300 contact-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
          </div>
          <div>
            <p class="coord-text text-white/40 mb-0.5">Instagram</p>
            <p class="text-white text-sm font-sans">{`@${instagram}`}</p>
          </div>
        </a>

        <div class="flex items-center gap-4">
          <div class="w-10 h-10 border flex items-center justify-center contact-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="coord-text text-white/40 mb-0.5">Localização</p>
            <p class="text-white text-sm font-sans">SP/PR/MG, Brasil</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact form -->
    <div id="contact-wrapper">
      <form id="contact-form" class="space-y-5">
        <div>
          <label class="coord-text text-white/50 block mb-2">Seu nome</label>
          <input
            type="text" required name="name"
            class="w-full bg-transparent border border-white/20 text-white px-4 py-3 text-sm focus:outline-none transition-colors font-sans"
            placeholder="Como posso te chamar?"
          />
        </div>
        <div>
          <label class="coord-text text-white/50 block mb-2">E-mail</label>
          <input
            type="email" required name="email"
            class="w-full bg-transparent border border-white/20 text-white px-4 py-3 text-sm focus:outline-none transition-colors font-sans"
            placeholder="seu@email.com"
          />
        </div>
        <div>
          <label class="coord-text text-white/50 block mb-2">Mensagem</label>
          <textarea
            required rows="5" name="message"
            class="w-full bg-transparent border text-white px-4 py-3 text-sm focus:outline-none transition-colors resize-none"
            style="border-color: rgba(255,255,255,0.2); font-family: 'DM Sans', sans-serif;"
            placeholder="Conte sobre seu projeto..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full btn-primary"
        >
          Enviar Mensagem
        </button>
      </form>

      <div id="success-msg" class="hidden border border-primary/40 p-8 text-center">
        <div class="mb-4 text-primary">
          <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-white text-xl font-semibold mb-2 font-display">Mensagem enviada!</h3>
        <p class="text-sm text-white/60 font-sans">Obrigado pelo contato. Responderei em breve.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('success-msg');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerText = 'Enviando...';
    }

    const formData = new FormData(form);

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
        
        setTimeout(() => {
          form.reset();
          form.classList.remove('hidden');
          success?.classList.add('hidden');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerText = 'Enviar Mensagem';
          }
        }, 8000);
      } else {
        const errorData = await response.json();
        alert(errorData.message || 'Erro ao enviar mensagem.');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = 'Enviar Mensagem';
        }
      }
    } catch (err) {
      console.error(err);
      alert('Erro de conexão. Tente novamente.');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerText = 'Enviar Mensagem';
      }
    }
  });
</script>

<style>
  .contact-icon-box {
    border-color: oklch(0.72 0.18 65 / 0.3);
  }

  .group:hover .contact-icon-box {
    background: var(--primary);
    border-color: var(--primary);
  }
</style>
