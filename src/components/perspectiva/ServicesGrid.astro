---

<section id="servicos" class="py-24 px-6 max-w-7xl mx-auto">
  <div>
    <div class="mb-12">
      <p class="coord-text mb-3" style="color: oklch(0.72 0.18 65 / 0.8);">/ 03 — Serviços</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white" style="font-family: 'Playfair Display', serif;">
        O que posso <span class="italic" style="color: oklch(0.72 0.18 65);">criar</span> para você
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {SERVICES.map((service, i) => (
        <div
          class="group p-6 border border-white/10 transition-all duration-500"
          style="border-color: rgba(255,255,255,0.1);"
          onmouseover={`this.style.borderColor='oklch(0.72 0.18 65 / 0.5)'; this.style.background='oklch(0.12 0.006 285)';`}
          onmouseout={`this.style.borderColor='rgba(255,255,255,0.1)'; this.style.background='transparent';`}
        >
          <div class="mb-5 transition-transform duration-300" style={`color: oklch(0.72 0.18 65);`}>
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-white text-lg font-semibold mb-3" style="font-family: 'Playfair Display', serif;">{service.title}</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.5); font-family: 'DM Sans', sans-serif; font-weight: 300;">{service.desc}</p>
          <div class="mt-5 h-px transition-all duration-500" style="background: transparent;"></div>
        </div>
      ))}
    </div>

    <!-- Full-width image banner -->
    <div class="mt-16 relative overflow-hidden h-64 md:h-80">
      <img src={SUNSET_IMG} alt="Pôr do sol capturado por drone" class="w-full h-full object-cover" />
      <div class="absolute inset-0 flex items-center" style="background: linear-gradient(to right, oklch(0.05 0.005 285 / 0.8), transparent);">
        <div class="px-8 md:px-16">
          <p class="coord-text mb-2" style="color: oklch(0.72 0.18 65 / 0.8);">Cada projeto é único</p>
          <h3 class="text-white text-2xl md:text-4xl font-bold max-w-md" style="font-family: 'Playfair Display', serif;">
            Vamos criar algo <span class="italic" style="color: oklch(0.72 0.18 65);">extraordinário</span>?
          </h3>
          <a
            href="#contato"
            class="mt-6 inline-block px-6 py-2.5 text-sm font-semibold transition-colors"
            style="background: oklch(0.72 0.18 65); color: oklch(0.08 0.005 285); font-family: 'DM Sans', sans-serif;"
            onmouseover="this.style.background='oklch(0.60 0.20 55)'"
            onmouseout="this.style.background='oklch(0.72 0.18 65)'"
          >
            Solicitar Orçamento
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
