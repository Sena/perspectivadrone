---
import { PortableText, Image } from "emdash/ui";

const { entry } = Astro.props;
const data = entry?.data || {};

const ABOUT_TITLE = data.title || "";
const ABOUT_IMG = data.image;
const ABOUT_CONTENT = data.content;
const ABOUT_TITLE_PARTS = ABOUT_TITLE.split(/##(.*?)##/g);
---

<section id="sobre" class="py-24 px-6 max-w-7xl mx-auto flex flex-col md:flex-row gap-16 items-start">
  <!-- Image container -->
  <div class="relative w-full md:w-1/2 group">
    <div class="relative overflow-hidden border border-white/10" {...entry?.edit?.image}>
       {typeof ABOUT_IMG === 'string' ? (
         <img src={ABOUT_IMG} alt="Flávio Sena" class="w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-110" />
       ) : (
         <Image image={ABOUT_IMG} class="w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-110" />
       )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    </div>
    
    <!-- Decorative border -->
    <div class="absolute -top-4 -left-4 w-full h-full border border-amber-400/20 -z-10 transition-all duration-500 group-hover:top-0 group-hover:left-0"></div>
  </div>

  <!-- Content side -->
  <div class="w-full md:w-1/2">
    <p class="coord-text mb-3 text-primary-80">/ 02 — SOBRE</p>
    <h2 class="text-5xl font-bold text-white mb-8 font-display" {...entry?.edit?.title}>
      {ABOUT_TITLE_PARTS.map((part, i) => (
        i % 2 === 1 
          ? <span class="italic text-primary">{part}</span> 
          : part
      ))}
    </h2>

    <div class="space-y-6 text-white/70 text-lg leading-relaxed font-sans font-light" {...entry?.edit?.content}>
       <PortableText value={ABOUT_CONTENT} />
    </div>
  </div>
</section>
