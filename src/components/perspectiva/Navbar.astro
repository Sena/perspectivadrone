---
const navLinks = [
  { label: "Início", href: "#inicio" },
  { label: "Portfólio", href: "#portfolio" },
  { label: "Sobre", href: "#sobre" },
  { label: "Serviços", href: "#servicos" },
  { label: "Contato", href: "#contato" },
];

const INSTAGRAM_SVG = `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`;
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#inicio" class="flex flex-col leading-none group" id="nav-logo">
      <span class="text-xl font-bold tracking-wide text-white transition-colors duration-300" style="font-family: 'Playfair Display', serif;" id="logo-text">
        Flávio Sena
      </span>
      <span class="coord-text text-[10px] mt-0.5">Fotografia & Drone</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link relative text-sm font-medium tracking-wide transition-colors duration-300 pb-1 text-white/70"
            style="font-family: 'DM Sans', sans-serif;"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Instagram CTA -->
    <a
      href="https://www.instagram.com/sena_o_outro/"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:flex items-center gap-2 px-4 py-2 border text-sm font-medium rounded-sm transition-all duration-300"
      style="border-color: oklch(0.72 0.18 65 / 0.6); color: oklch(0.72 0.18 65); font-family: 'DM Sans', sans-serif;"
      onmouseover="this.style.background='oklch(0.72 0.18 65)'; this.style.color='oklch(0.08 0.005 285)'"
      onmouseout="this.style.background='transparent'; this.style.color='oklch(0.72 0.18 65)'"
    >
      <Fragment set:html={INSTAGRAM_SVG} />
      @sena_o_outro
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-toggle" class="md:hidden transition-colors" style="color: rgba(255,255,255,0.8);">
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t px-6 py-6" style="background: oklch(0.08 0.005 285 / 0.98); backdrop-filter: blur(12px); border-color: oklch(0.22 0.008 285);">
    <ul class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link text-white/80 text-base font-medium transition-colors block"
            style="font-family: 'DM Sans', sans-serif;"
            onmouseover="this.style.color='oklch(0.72 0.18 65)'"
            onmouseout="this.style.color='rgba(255,255,255,0.8)'"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-white/10">
        <a
          href="https://www.instagram.com/sena_o_outro/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm font-medium"
          style="color: oklch(0.72 0.18 65);"
        >
          <Fragment set:html={INSTAGRAM_SVG} />
          @sena_o_outro
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const toggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');
  const logoText = document.getElementById('logo-text');

  // Scroll handler
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav!.style.cssText = 'background: oklch(0.08 0.005 285 / 0.95); backdrop-filter: blur(12px); border-bottom: 1px solid oklch(0.22 0.008 285);';
    } else {
      nav!.style.cssText = '';
    }
  });

  // Logo hover
  logoText?.parentElement?.addEventListener('mouseover', () => {
    logoText.style.color = 'oklch(0.72 0.18 65)';
  });
  logoText?.parentElement?.addEventListener('mouseout', () => {
    logoText.style.color = 'white';
  });

  // Mobile toggle
  toggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    } else {
      mobileMenu?.classList.remove('hidden');
      iconMenu?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    }
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // Active link highlight on scroll
  const sections = ['inicio', 'portfolio', 'sobre', 'servicos', 'contato'];
  const navLinks = document.querySelectorAll('.nav-link');

  window.addEventListener('scroll', () => {
    let current = 'inicio';
    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el && window.scrollY >= el.offsetTop - 100) current = id;
    });

    navLinks.forEach(link => {
      const href = link.getAttribute('href');
      if (href === `#${current}`) {
        (link as HTMLElement).style.color = 'oklch(0.72 0.18 65)';
      } else {
        (link as HTMLElement).style.color = 'rgba(255,255,255,0.7)';
      }
    });
  });
</script>
