---
import { Image } from "emdash/ui";

interface Service {
	title: string;
	description?: string;
	image?: {
		src?: string;
		alt?: string;
	};
	order?: number;
}

interface Props {
	title: string;
	services: Service[];
}

const { title, services } = Astro.props;
---

<section class="sector-services">
	<div class="container">
		<h2 class="section-title">{title}</h2>
		
		<div class="grid">
			{services.map((service) => (
				<div class="service-card">
					<div class="image-wrapper">
						{service.image && (
							<Image 
								image={service.image} 
								class="card-image"
							/>
						)}
						<div class="card-overlay"></div>
					</div>
					<div class="card-content">
						<h3 class="card-title">{service.title}</h3>
						{service.description && <p class="card-description">{service.description}</p>}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.sector-services {
		padding: var(--spacing-20) 0;
		background: #000;
	}

	.container {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-6);
	}

	.section-title {
		font-size: clamp(2rem, 5vw, 3rem);
		color: #fff;
		margin-bottom: var(--spacing-12);
		text-align: center;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: var(--spacing-8);
	}

	.service-card {
		position: relative;
		border-radius: 8px;
		overflow: hidden;
		background: #111;
		transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		border: 1px solid #1a1a1a;
	}

	.service-card:hover {
		transform: translateY(-8px);
		border-color: #333;
	}

	.image-wrapper {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
	}

	.card-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.service-card:hover .card-image {
		transform: scale(1.05);
	}

	.card-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.8) 100%);
	}

	.card-content {
		padding: var(--spacing-8);
	}

	.card-title {
		font-size: 1.5rem;
		color: #fff;
		margin-bottom: var(--spacing-2);
	}

	.card-description {
		font-size: 1rem;
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	@media (max-width: 600px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
