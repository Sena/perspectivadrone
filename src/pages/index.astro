---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import HeroCinematic from "../components/perspectiva/HeroCinematic.astro";
import FPVShowcase from "../components/perspectiva/FPVShowcase.astro";
import SectorServices from "../components/perspectiva/SectorServices.astro";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

// Fetch cinematic content
const { entries: showreels, cacheHint: showreelCache } = await getEmDashCollection("showreel");
const { entries: services, cacheHint: servicesCache } = await getEmDashCollection("services");
const { siteTitle, siteTagline, siteWhatsapp } = resolveBlogSiteIdentity(await getSiteSettings());

// Set cache hints for both collections
Astro.cache.set(showreelCache);
Astro.cache.set(servicesCache);

// Identify components from data
const heroData = showreels.find(s => s.id === "hero-showreel")?.data;
const fpvData = showreels.find(s => s.id === "fpv-single-take")?.data;
const sectorServices = services
	.map(s => s.data)
	.sort((a, b) => (Number(a.order) || 0) - (Number(b.order) || 0));
---

<Base title={siteTitle} description={siteTagline}>
	<main class="cinematic-home">
		{heroData && (
			<HeroCinematic 
				title={heroData.title} 
				videoUrl={heroData.video} 
				poster={heroData.poster}
				whatsappUrl={siteWhatsapp}
			/>
		)}

		{fpvData && (
			<FPVShowcase 
				title={fpvData.title}
				description={fpvData.description}
				videoUrl={fpvData.video}
				poster={fpvData.poster}
			/>
		)}

		{sectorServices.length > 0 && (
			<SectorServices 
				title="Nossos Setores"
				services={sectorServices}
			/>
		)}
	</main>
</Base>

<style>
	.cinematic-home {
		background: #000;
	}
</style>
