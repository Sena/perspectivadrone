					"hero_title": "O mundo é mais bonito lá de cima.",
					"hero_subtitle": "Apaixonado por viagens de moto, fotografia e natureza — capturando momentos únicos e admirando o pôr do sol.",
					"hero_image": { "url": "https://d36hbw14aib5lz.cloudfront.net/310519663568009244/9oWeQAjFk7GoTWpFXegazj/hero_aerial-VVZGySyHKtXCrUgRiWHtMu.webp?Expires=1807954674&Signature=WmI7fn74BnTaUQPlsNWyXaIdk1daI4SlvblJqhc43aNnctPixPye5ZQ7oLndF2zwbrZ982R4BTzpVeRP7yIq~2hodrS3qseEFeNeBiEwcjXZrlaXUm15UOddCFIZcDz0~gv9Z62CNLAwsPNel4JWBzQu1a9Y7kQKwIkoftm29EwuZbtXnpEX3g2WRKAE4C-oBfI2Cm8Dexs8NrTPVxv4e2DyeA4FUPkhjnKlvjgikLqpICdng7mIOQBentq7keEGBv3Tr-68cjQrXUD2u1WOOnqU~FmW5YXeGebSg91imSstqE3tbIO7tDy4WOtXoWDblfUcU3m1ObVMbHABLp-msw__&Key-Pair-Id=K1MP89RTKNH4J" },
					"about_title": "Sena, o outro olhar",
					"about_content": [
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Sou Flávio Sena, fotógrafo e piloto de drone apaixonado por descobrir o Brasil de perspectivas que poucos têm a chance de ver. Minha câmera e meu drone são extensões do meu olhar — sempre buscando o ângulo que conta a história completa." }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "As viagens de moto são meu portal para lugares remotos, cachoeiras escondidas e estradas que o Google Maps ainda não mapeou direito." }] }
					],
					"about_image": { "url": "https://d36hbw14aib5lz.cloudfront.net/310519663568009244/9oWeQAjFk7GoTWpFXegazj/moto_estrada-WBtucu3AC4pLKfQ4csSnLc.webp?Expires=1807954676&Signature=JM7f4S39Gwos6ycaWvUIOphRn2gE-Eh1pT0j6Y4r11vQZZ3394a2~l~B2ZcX1PVUK-mitiyA539MYCJKGzBcVsZ654NBy5Z8g-HozxDg3DYE3m1KDVh4ZHSYTHDtKj8t9gch9SVXMZnBnCTPdTBxpwLKD-m3oo69MAu4qGF-3gRYPPgUrfJNjNtxxH~W-W1vdnveED98o-Esve9tOKYq6-DckPdyRxTZNqe4s~hQFnXVhxLISdZZqmiV0bTTUri3asqNLBVIODk6TEjgBvTKu9tZFsB82FtejIJr1T9n45DnW~yBcjZT4szDD6G9xyviwdDGNESQxpcnwaOR0mcxMA__&Key-Pair-Id=K1MP89RTKNH4J" }
